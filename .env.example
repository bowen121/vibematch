# Copy to .env and fill in. .env is gitignored.
#
# Two auth modes are supported (pick one):
#
# 1. New API Token (recommended) — get from
#    https://www.kaggle.com/settings/account → "Generate New Token".
#    Single string starting with "KGAT_". Requires kaggle>=1.8.0.
KAGGLE_API_TOKEN=KGAT_your_token_here
#
# 2. Legacy credentials — same settings page → "Create Legacy API Key".
#    Downloads kaggle.json with username + key. Both fields required.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_32_char_hex_key
