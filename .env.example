# =============================================================================
# VibeMatch — environment template
# =============================================================================
# Copy this file to `.env` (which is gitignored) and fill in the value below:
#
#     cp .env.example .env
#
# Then edit `.env` and replace the placeholder with your real Kaggle token.
# Anything you put in `.env` stays local — it will not be committed.
# =============================================================================


# ----- Kaggle authentication (required to download the datasets) -------------
#
# We use the new-style Kaggle "API Token" (recommended over the legacy
# username+key flow). To get one:
#
#   1. Sign in at https://www.kaggle.com
#   2. Click your profile picture (top right) → "Settings"
#      (direct link: https://www.kaggle.com/settings/account)
#   3. Scroll to the "API" section → click "Generate New Token"
#   4. Copy the token string — it starts with "KGAT_..."
#   5. Paste it below as the value of KAGGLE_API_TOKEN, replacing the
#      placeholder. Don't add quotes around it.
#
# Requires `kaggle>=1.8.0` (already pinned in requirements.txt).
#
# After this, `python scripts/prepare_data.py` will Just Work.
#
KAGGLE_API_TOKEN=KGAT_paste_your_token_here


# ----- Legacy auth (only if the new token doesn't work) ----------------------
#
# Alternative: on the same Kaggle settings page, click "Create Legacy API Key"
# instead. That downloads a `kaggle.json` file with two fields. You can either:
#
#   (a) move the file:
#       mkdir -p ~/.kaggle && mv ~/Downloads/kaggle.json ~/.kaggle/
#       chmod 600 ~/.kaggle/kaggle.json
#
#   (b) OR uncomment these two lines and paste the values from kaggle.json:
#
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_32_char_hex_key
